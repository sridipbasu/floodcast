        "estimated_return_period"
      ]
    },
    "target_scaler": {
      "file": "target_scaler.pkl",
      "type": "StandardScaler()",
      "fit_on": "train split only",
      "applies_to": ["streamflow_delta"],
      "mean": 0.0108,
      "scale": 144.7006,
      "note": "Used for INVERSE transform only during inference — never forward transform at inference time"
    }
  },
  "inference_notes": {
    "step1": "Apply yj_transformer to raw_input_cols, rename to _yj suffix",
    "step2": "Apply mm_scaler to antecedent/capacity cols",
    "step3": "Apply feature_scaler to delta/static/routing cols",
    "step4": "Feed SEQ_LEN=15 timesteps of dynamic_cols (in exact order) into LSTM",
    "step5": "Concatenate flat_cols (in exact order) + lstm_hidden_state (256-dim) → XGBoost",
    "step6": "hybrid_pred_delta_scaled = lstm_pred + xgb_correction",
    "step7": "raw_delta = target_scaler.inverse_transform([[hybrid_pred_delta_scaled]])",
    "step8": "pred_raw_streamflow = prev_raw_streamflow + raw_delta"
  }
