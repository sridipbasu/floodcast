  "input_scalers": {
    "yj_transformer": {
      "file": "yj_transformer.pkl",
      "type": "PowerTransformer(method='yeo-johnson', standardize=True)",
      "fit_on": "train split only",
      "raw_input_cols": [
        "UP_AREA",
        "rain_basin_size_interaction",
